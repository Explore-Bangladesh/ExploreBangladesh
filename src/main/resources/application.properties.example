# Application name
spring.application.name=ExploreBangladesh

# H2 Database Configuration (in-memory)
#spring.datasource.url=jdbc:h2:mem:testdb
#spring.datasource.driverClassName=org.h2.Driver
#spring.datasource.username=sa
#spring.datasource.password=
#spring.jpa.database-platform=org.hibernate.dialect.H2Dialect
#spring.jpa.hibernate.ddl-auto=update
#spring.h2.console.enabled=true
#spring.h2.console.path=/h2-console


# MySQL Configuration
spring.datasource.url=jdbc:mysql://localhost:3306/explore_bangladesh?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=YOUR_DB_USERNAME
spring.datasource.password=YOUR_DB_PASSWORD
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA Configuration
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=true
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.open-in-view=false
spring.h2.console.enabled=false

# Basic Security
spring.security.user.name=test
spring.security.user.password=YOUR_SECURITY_PASSWORD

geoapify.api.key=YOUR_GEOAPIFY_API_KEY
geoapify.base-url=https://api.geoapify.com/v2/places

amadeus.api.key=YOUR_AMADEUS_API_KEY
amadeus.api.secret=YOUR_AMADEUS_API_SECRET
amadeus.base-url=https://test.api.amadeus.com

# Country settings
hotels.country.code=BD
hotels.country.name=Bangladesh

# JWT configuration
# Use a strong 32+ byte value in production via environment variable.
jwt.secret=${JWT_SECRET:0b5983a8b291ce0229f3e60617f93b620b347d53a5454e258aa1b6742861dfe6}
jwt.expiration-ms=${JWT_EXPIRATION_MS:86400000}

# Alternate namespaced JWT configuration (supported by JwtService)
security.jwt.secret=${SECURITY_JWT_SECRET:${jwt.secret}}
security.jwt.access-ttl-seconds=${SECURITY_JWT_ACCESS_TTL_SECONDS:86400}
security.jwt.refresh-ttl-seconds=${SECURITY_JWT_REFRESH_TTL_SECONDS:604800}
security.jwt.issuer=${SECURITY_JWT_ISSUER:ExploreBangladesh}
security.jwt.token-type=${SECURITY_JWT_TOKEN_TYPE:Bearer}
security.jwt.refresh-cookie-name=${SECURITY_JWT_REFRESH_COOKIE_NAME:REFRESH_TOKEN}
security.jwt.refresh-cookie-secure=${SECURITY_JWT_REFRESH_COOKIE_SECURE:false}
security.jwt.refresh-cookie-http-only=${SECURITY_JWT_REFRESH_COOKIE_HTTP_ONLY:true}
security.jwt.refresh-cookie-same-site=${SECURITY_JWT_REFRESH_COOKIE_SAME_SITE:Lax}
security.jwt.refresh-cookie-path=${SECURITY_JWT_REFRESH_COOKIE_PATH:/}

# JWT cookie settings
# Keep false for local HTTP development, set true in HTTPS production.
jwt.cookie.name=${JWT_COOKIE_NAME:AUTH_TOKEN}
jwt.cookie.secure=${JWT_COOKIE_SECURE:true}
jwt.cookie.http-only=${JWT_COOKIE_HTTP_ONLY:true}
jwt.cookie.same-site=${JWT_COOKIE_SAME_SITE:Lax}

# Comma-separated list of front-end origins allowed by CORS
app.cors.front-end-url=${APP_CORS_FRONT_END_URL:http://127.0.0.1:5500,http://127.0.0.1:5501,http://localhost:5500,http://localhost:5501,http://localhost:8080}
