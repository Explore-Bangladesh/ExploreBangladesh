# MySQL Configuration
spring.datasource.url=jdbc:mysql://localhost:3306/explore_bangladesh_test_01?createDatabaseIfNotExist=true&useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
spring.datasource.username=root
spring.datasource.password=CE23017@lisan
spring.datasource.driver-class-name=com.mysql.cj.jdbc.Driver

# JPA Configuration
spring.jpa.hibernate.ddl-auto=update
spring.jpa.show-sql=false
spring.jpa.properties.hibernate.dialect=org.hibernate.dialect.MySQLDialect
spring.jpa.properties.hibernate.format_sql=true
spring.jpa.open-in-view=false
spring.h2.console.enabled=false
spring.jpa.properties.hibernate.jdbc.batch_size=20
spring.jpa.properties.hibernate.order_inserts=true
spring.jpa.properties.hibernate.order_updates=true
spring.jpa.defer-datasource-initialization=true
spring.sql.init.mode=always

# Basic Security
spring.security.user.name=test
spring.security.user.password=test

geoapify.api.key=2a42881f098048d7ae41b52f7c540f33
geoapify.base-url=https://api.geoapify.com/v2/places

amadeus.api.key=PLsfMGlu7EvnHhjz3BXEsEJoAhT494aw
amadeus.api.secret=JgwrB8Vn9eG2g8HK
amadeus.base-url=https://test.api.amadeus.com

# Country settings
hotels.country.code=BD
hotels.country.name=Bangladesh

# JWT configuration
# Use a strong 32+ byte value in production via environment variable.
jwt.secret=${JWT_SECRET:0b5983a8b291ce0229f3e60617f93b620b347d53a5454e258aa1b6742861dfe6}
jwt.expiration-ms=${JWT_EXPIRATION_MS:86400000}

# Alternate namespaced JWT configuration (supported by JwtService)
security.jwt.secret=${SECURITY_JWT_SECRET:${jwt.secret}}

# Spring AI - Google Generative AI Configuration (Gemini - Free Tier)
# Get your API key from: https://ai.google.dev/
# IMPORTANT: Set via environment variable GOOGLE_API_KEY (do not hardcode)
spring.ai.google.genai.api-key=AIzaSyB7WAYEnXwbVCN4D80yzOaErqYbpQgrmic
spring.ai.google.genai.chat.options.model=gemini-2.5-flash
spring.ai.google.genai.chat.options.temperature=0.7
security.jwt.access-ttl-seconds=${SECURITY_JWT_ACCESS_TTL_SECONDS:86400}
security.jwt.refresh-ttl-seconds=${SECURITY_JWT_REFRESH_TTL_SECONDS:604800}
security.jwt.issuer=${SECURITY_JWT_ISSUER:ExploreBangladesh}
security.jwt.token-type=${SECURITY_JWT_TOKEN_TYPE:Bearer}
security.jwt.refresh-cookie-name=${SECURITY_JWT_REFRESH_COOKIE_NAME:REFRESH_TOKEN}
security.jwt.refresh-cookie-secure=${SECURITY_JWT_REFRESH_COOKIE_SECURE:false}
security.jwt.refresh-cookie-http-only=${SECURITY_JWT_REFRESH_COOKIE_HTTP_ONLY:true}
security.jwt.refresh-cookie-same-site=${SECURITY_JWT_REFRESH_COOKIE_SAME_SITE:Lax}
security.jwt.refresh-cookie-path=${SECURITY_JWT_REFRESH_COOKIE_PATH:/}

# JWT cookie settings
# Keep false for local HTTP development, set true in HTTPS production.
jwt.cookie.name=${JWT_COOKIE_NAME:AUTH_TOKEN}
jwt.cookie.secure=${JWT_COOKIE_SECURE:true}
jwt.cookie.http-only=${JWT_COOKIE_HTTP_ONLY:true}
jwt.cookie.same-site=${JWT_COOKIE_SAME_SITE:Lax}

spring.security.oauth2.client.registration.google.client-id=${GOOGLE_CLIENT_ID:}
spring.security.oauth2.client.registration.google.client-secret=${GOOGLE_CLIENT_SECRET:}
spring.security.oauth2.client.registration.google.scope=email,profile,openid

# Flyway Database Migration Configuration
spring.flyway.locations=classpath:db/migration
spring.flyway.enabled=false
spring.flyway.baseline-on-migrate=true
spring.flyway.out-of-order=false

# Comma-separated list of front-end origins allowed by CORS
app.cors.front-end-url=${APP_CORS_FRONT_END_URL:http://127.0.0.1:5500,http://127.0.0.1:5501,http://localhost:5500,http://localhost:5501,http://localhost:8080}

# OAuth2 Frontend Success Redirect
app.auth.frontend.success-redirect=${APP_AUTH_FRONTEND_SUCCESS_REDIRECT:http://localhost:8080/index.html}